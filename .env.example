# Browser-exposed (safe — anon key is RLS-gated). Used by the SPA.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side ONLY — set in the Vercel project env, never committed, never
# shipped to the browser. The /api/ai/* proxy reads these.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SUPABASE_URL=
SUPABASE_ANON_KEY=
